# PostgreSQL connection string (Neon, Supabase, Railway, local Postgres, ...)
# Example: postgres://user:password@host:5432/dbname
DATABASE_URL=postgres://user:password@localhost:5432/hospital

# Long random secret used to sign JWT access tokens.
# Generate one with:  openssl rand -hex 32
JWT_SECRET=replace-me-with-a-long-random-string

# Port the Express API server listens on (frontend expects 8080 by default)
PORT=8080

# Set to "production" when deploying
NODE_ENV=development
